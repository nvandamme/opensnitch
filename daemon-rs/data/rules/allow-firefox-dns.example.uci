config rule 'allow_firefox_dns'
	option created '2026-03-27T00:00:00Z'
	option updated '2026-03-27T00:00:00Z'
	option name 'allow-firefox-dns'
	option description 'Allow Firefox DNS queries'
	option enabled '1'
	option precedence '0'
	option nolog '0'
	option action 'allow'
	option duration 'always'
	list match_process_path '/usr/lib/firefox/firefox'
	list match_dest_port '53'

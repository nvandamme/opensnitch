[Unit]
Description=Application firewall OpenSnitch (Rust daemon)
Documentation=https://github.com/evilsocket/opensnitch/wiki
Wants=network.target
After=network.target

[Service]
# Type=notify: the daemon sends READY=1 via sd_notify once the runtime is fully
# initialised, and RELOADING=1/READY=1 on SIGHUP live-reload.  This requires
# libsystemd (or the NOTIFY_SOCKET datagram path) to be reachable at runtime.
Type=notify
NotifyAccess=main

ExecStart=@PREFIX@/bin/opensnitchd-rs
ExecReload=/bin/kill -HUP $MAINPID

Restart=on-failure
RestartSec=5
TimeoutStartSec=60
TimeoutStopSec=15

# opensnitchd-rs needs:
#   CAP_NET_ADMIN  – nftables / nfqueue verdict and firewall rule management
#   CAP_NET_RAW    – raw/packet sockets for connection monitoring
#   CAP_SYS_PTRACE – /proc/<pid>/… inspection for process attribution
#   CAP_BPF        – eBPF program load/map operations (kernel ≥ 5.8)
#   CAP_PERFMON    – eBPF perf-event access (kernel ≥ 5.8; replaces CAP_SYS_ADMIN for BPF)
#   CAP_SYS_ADMIN  – eBPF on older kernels (< 5.8) that do not have CAP_BPF/CAP_PERFMON
#
# Package maintainers: keep CAP_SYS_ADMIN in AmbientCapabilities only when
# targeting kernels < 5.8; omit it on modern distributions.
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_SYS_PTRACE CAP_BPF CAP_PERFMON CAP_SYS_ADMIN
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_SYS_PTRACE CAP_BPF CAP_PERFMON CAP_SYS_ADMIN

# Security hardening – tighten as your deployment allows.
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
PrivateDevices=false
NoNewPrivileges=false
ReadWritePaths=@SYSCONFDIR@/opensnitchd /run/opensnitchd /tmp

# Runtime directory for the gRPC Unix socket.
RuntimeDirectory=opensnitchd
RuntimeDirectoryMode=0750

[Install]
WantedBy=multi-user.target

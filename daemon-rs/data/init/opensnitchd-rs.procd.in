#!/bin/sh /etc/rc.common
# Application firewall OpenSnitch (Rust daemon) — OpenWrt / procd init script
# Template: @PREFIX@ and @SYSCONFDIR@ are substituted at install time by make install-rs.
#
# procd does not forward NOTIFY_SOCKET; the daemon detects the missing socket
# and falls back to log-based lifecycle state reporting automatically.

USE_PROCD=1

# Start after network (20) and firewall (20); stop before them.
START=25
STOP=85

OPENSNITCHD_RS_BIN="@PREFIX@/@BINDIR@/opensnitchd-rs"
OPENSNITCHD_RS_CONF="@SYSCONFDIR@/opensnitchd/default-config.json"
OPENSNITCHD_RS_RULES="@SYSCONFDIR@/opensnitchd/rules"
OPENSNITCHD_RS_PIDFILE="/var/run/opensnitchd-rs.pid"
OPENSNITCHD_RS_LOGFILE="/var/log/opensnitchd-rs.log"

start_service() {
    mkdir -p "${OPENSNITCHD_RS_RULES}"

    procd_open_instance opensnitchd-rs

    procd_set_param command "${OPENSNITCHD_RS_BIN}"

    # Respawn on unexpected exit: threshold 3600 s, restart delay 5 s, max 5 retries.
    procd_set_param respawn 3600 5 5

    # Reload config + rules on SIGHUP (maps to daemon's live-reload path).
    procd_set_param reload_signal HUP

    # Track config file changes for automatic reload triggers.
    procd_set_param file "${OPENSNITCHD_RS_CONF}"

    procd_set_param stdout 1
    procd_set_param stderr 1

    procd_set_param pidfile "${OPENSNITCHD_RS_PIDFILE}"

    procd_close_instance
}

reload_service() {
    local pid
    pid="$(cat "${OPENSNITCHD_RS_PIDFILE}" 2>/dev/null)"
    if [ -n "${pid}" ]; then
        kill -HUP "${pid}" 2>/dev/null && echo "opensnitchd-rs: SIGHUP sent (pid ${pid})"
    else
        echo "opensnitchd-rs: no pidfile; service may not be running" >&2
        return 1
    fi
}

service_triggers() {
    # Re-run reload_service when the OpenWrt network interface comes up.
    procd_add_reload_trigger "network"
}
